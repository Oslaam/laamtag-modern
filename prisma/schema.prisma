// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  walletAddress String      @id @unique
  laamPoints    Int         @default(0)
  rank          String      @default("Bronze")
  lastCheckIn   DateTime?
  streakCount   Int         @default(0)
  quests        UserQuest[] // Renamed from 'completed' for clarity
}

model Quest {
  id           String      @id @default(uuid())
  title        String
  reward       Int
  type         String      @default("basic") 
  limit        Int?        
  claimedCount Int         @default(0)
  users        UserQuest[]
}

model UserQuest {
  id          String      @id @default(cuid())
  userId      String
  questId     String
  status      QuestStatus @default(PENDING)
  proofLink   String?
  completedAt DateTime    @default(now())
  updatedAt   DateTime    @updatedAt 
  user        User        @relation(fields: [userId], references: [walletAddress])
  quest       Quest       @relation(fields: [questId], references: [id])

  // THIS IS THE FIX: This allows prisma.userQuest.findUnique({ where: { userId_questId: ... } })
  @@unique([userId, questId]) 
}

model ClaimedNFT {
  mintAddress String   @id @unique
  claimedBy   String
  claimedAt   DateTime @default(now())
}