generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress      String           @id @unique
  username      String?
  laamPoints         Float              @default(0)
  rank               String           @default("Bronze")
  lastCheckIn        DateTime?
  streakCount        Int              @default(0)
  personalMinted     Int              @default(0)
  tagTickets         Float              @default(0)
  totalTagPurchased  Int              @default(0)
  isAdmin            Boolean          @default(false)
  quests             UserQuest[]
  activities         Activity[]
  pendingRewards     PendingReward[]
  pushSubscriptions  PushSubscription[]
  shooterLevel   Int      @default(1)
  shooterStage   Int      @default(1)
  skrBalance       Float   @default(0)
  weaponLevel        Int              @default(1)
  shieldLevel        Int              @default(0)
  shoeLevel          Int              @default(1)
  lifeLevel          Int              @default(1)
  currentStage       Int              @default(1)
  hasPaidDiceEntry   Boolean          @default(false)
  hasResistanceUnlocked Boolean       @default(false)
  boosts             MultiplierBoost[]
  lastLaamCheckIn DateTime?
  lastTagCheckIn  DateTime?
}

model Activity {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [walletAddress])
  type          String   // e.g., "SPIN_COST", "SPIN_WIN", "TAG_PURCHASE" , "SWAP"
  asset         String   // e.g., "TAG", "LAAM", "SOL", "USDC" , "SOL/USDC"
  amount        Float
  signature       String? // To store the Solana TX hash
  createdAt     DateTime @default(now())
}

model PendingReward {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [walletAddress])
  asset         String   // "SOL" or "USDC"
  type      String   @default("REWARD") // <--- "REWARD" or "REFUND" on raffle
  amount        Float
  isClaimed     Boolean  @default(false)
  createdAt     DateTime @default(now())
}
model Quest {
  id           String      @id @default(uuid())
  title        String
  reward       Int
  type         String      @default("basic")
  link         String?  
  limit        Int?
  claimedCount Int         @default(0)
  users        UserQuest[]
}

model UserQuest {
  id          String      @id @default(cuid())
  userId      String
  questId     String
  status      QuestStatus @default(PENDING)
  proofLink   String?
  completedAt DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  quest       Quest       @relation(fields: [questId], references: [id])
  user        User        @relation(fields: [userId], references: [walletAddress])

  @@unique([userId, questId])
}

model ClaimedNFT {
  mintAddress String   @id @unique
  claimedBy   String
  claimedAt   DateTime @default(now())
}

model GuessGame {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastAttempt   DateTime @default(now())
  attempts      Int      @default(0)
  isLocked      Boolean  @default(false)
  pendingPoints Int      @default(0)
  currentTarget Int?
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model StakedNFT {
  id           String   @id @default(cuid())
  mintAddress  String   @unique  // <--- CRITICAL: This prevents double-staking
  ownerAddress String
  stakedAt     DateTime @default(now())
  lastClaimed  DateTime @default(now())
  // signature String? // Add this if you want to store the TX proof
}

model SupportTicket {
  id            String   @id @default(cuid())
  walletAddress String
  type          String   // Complaint or Suggestion
  name          String
  email         String
  title         String
  description   String   @db.Text
  status        String   @default("Pending") // Pending, Resolved
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

model RewardHistory {
  id            String   @id @default(cuid())
  walletAddress String
  mintAddress   String
  laamEarned    Float
  tagEarned     Float
  unstakedAt    DateTime @default(now())

  @@index([walletAddress])
}


model MultiplierBoost {
  id          String   @id @default(cuid())
  userAddress String
  mintAddress String   // Added this to target specific NFTs
  user        User     @relation(fields: [userAddress], references: [walletAddress])
  multiplier  Float    
  activatedAt DateTime @default(now()) // When the boost starts working
  expiresAt   DateTime
  purchasedAt DateTime @default(now())

  @@index([userAddress])
  @@index([mintAddress])
}

model RafflePool {
  id           String        @id @default(cuid())
  entryFee     Float         // 500, 1000, etc.
  status       String        @default("OPEN") // OPEN, DRAWING, COMPLETED, EXPIRED
  winnerAddress String?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  entries      RaffleEntry[]
}

model RaffleEntry {
  id            String     @id @default(cuid())
  poolId        String
  walletAddress String
  txSignature   String     @unique
  status        String      @default("PENDING")
  pool          RafflePool @relation(fields: [poolId], references: [id])
  createdAt     DateTime   @default(now())

  @@unique([poolId, walletAddress]) // Prevents one user entering same pool twice
}

model PushSubscription {
  id            String   @id @default(cuid())
  walletAddress String
  user          User     @relation(fields: [walletAddress], references: [walletAddress])
  subscription  Json     
  userAgent     String?  // Optional: helps you identify which device this is
  createdAt     DateTime @default(now())
  @@unique([walletAddress, userAgent])
}

model ResistanceScore {
  id            String   @id @default(cuid())
  walletAddress String
  initialGrid   String   // Store as a comma-separated string or JSON
  score         Int
  createdAt     DateTime @default(now())
  
  @@index([walletAddress])
  @@index([createdAt]) // For Daily Leaderboard filtering
}