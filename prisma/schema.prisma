generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress  String      @id @unique
  laamPoints     Int         @default(0)
  rank           String      @default("Bronze")
  lastCheckIn    DateTime?
  streakCount    Int         @default(0)
  personalMinted Int         @default(0)
  tagTickets     Int         @default(0)
  quests         UserQuest[]
}

model Quest {
  id           String      @id @default(uuid())
  title        String
  reward       Int
  type         String      @default("basic")
  limit        Int?
  claimedCount Int         @default(0)
  users        UserQuest[]
}

model UserQuest {
  id          String      @id @default(cuid())
  userId      String
  questId     String
  status      QuestStatus @default(PENDING)
  proofLink   String?
  completedAt DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  quest       Quest       @relation(fields: [questId], references: [id])
  user        User        @relation(fields: [userId], references: [walletAddress])

  @@unique([userId, questId])
}

model ClaimedNFT {
  mintAddress String   @id @unique
  claimedBy   String
  claimedAt   DateTime @default(now())
}

model GuessGame {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastAttempt   DateTime @default(now())
  attempts      Int      @default(0)
  isLocked      Boolean  @default(false)
  pendingPoints Int      @default(0)
  currentTarget Int?
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model StakedNFT {
  id            String   @id @default(cuid())
  mintAddress   String   @unique
  ownerAddress  String
  stakedAt      DateTime @default(now())
  lastClaimed   DateTime @default(now())
  isLocked      Boolean  @default(true)
}