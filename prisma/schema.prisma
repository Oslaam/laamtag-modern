generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress      String           @id @unique
  username      String?
  laamPoints         Float              @default(0)
  tagTickets         Float              @default(0)
  warCredits             Float              @default(0)
  rank               String           @default("Bronze")
  claimedBadges UserBadge[]
  lastCheckIn        DateTime?
  streakCount        Int              @default(0)
  personalMinted     Int              @default(0)
  warriorMinted Int      @default(0)
  deployedWarriors DeployedWarrior[]
  lastWarriorMint    DateTime?
  lastWarriorMintBatch Int   @default(-1)
  totalTagPurchased  Int              @default(0)
  isAdmin            Boolean          @default(false)
  quests             UserQuest[]
  activities         Activity[]
  pendingRewards     PendingReward[]
  pushSubscriptions  PushSubscription[]
  shooterLevel   Int      @default(1)
  shooterStage   Int      @default(1)
  skrBalance       Float   @default(0)
  warriorItems   WarriorInventory[]
  weaponLevel        Int              @default(1)
  shieldLevel        Int              @default(0)
  shoeLevel          Int              @default(1)
  lifeLevel          Int              @default(1)
  currentStage       Int              @default(1)
  hasPaidDiceEntry   Boolean          @default(false)
  hasResistanceUnlocked Boolean       @default(false)
  hasPulseHunterUnlocked Boolean @default(false)
  hasPlinkoUnlocked      Boolean            @default(false)
  boosts             MultiplierBoost[]
  lastLaamCheckIn DateTime?
  lastTagCheckIn  DateTime?
  hasAccess          Boolean          @default(false)
  referralCode     String?  @unique // Their unique code (e.g., "TAG-X9Z2")
  referredBy       String?          // The wallet address of the person who invited them
  // Relations
  referrer         User?    @relation("UserReferrals", fields: [referredBy], references: [walletAddress])
  referrals        User[]   @relation("UserReferrals")
  referralProgress Float @default(0) // 0 to 100
  claimableRewards Int   @default(0) // Number of crates ready to claim
  friendsSent           Friendship[]      @relation("SentFriends")
  friendsReceived       Friendship[]      @relation("ReceivedFriends")
  notifications         Notification[]
}

model Friendship {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  status      String   @default("PENDING") // PENDING, ACCEPTED
  createdAt   DateTime @default(now())
  streak      Int      @default(0)
  lastPokeAt  DateTime @default(now())
  lastPokedBy String? 

  sender      User     @relation("SentFriends", fields: [senderId], references: [walletAddress])
  receiver    User     @relation("ReceivedFriends", fields: [receiverId], references: [walletAddress])

  @@unique([senderId, receiverId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "FRIEND_REQUEST", "GAME_INVITE"
  message     String
  fromAddress String?  // The wallet that triggered the alert
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [walletAddress])

  @@index([userId])
}

model Activity {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [walletAddress])
  type          String   // e.g., "SPIN_COST", "SPIN_WIN", "TAG_PURCHASE" , "SWAP"
  asset         String   // e.g., "TAG", "LAAM", "SOL", "USDC" , "SOL/USDC"
  amount        Float
  signature       String? // To store the Solana TX hash
  createdAt     DateTime @default(now())
}

model PendingReward {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [walletAddress])
  asset         String   // "SOL" or "USDC"
  type      String   @default("REWARD") // <--- "REWARD" or "REFUND" on raffle
  amount        Float
  isClaimed     Boolean  @default(false)
  createdAt     DateTime @default(now())
}
model Quest {
  id           String      @id @default(uuid())
  title        String
  reward       Int
  type         String      @default("basic")
  link         String?  
  limit        Int?
  claimedCount Int         @default(0)
  users        UserQuest[]
  createdAt    DateTime    @default(now())
}

model UserQuest {
  id          String      @id @default(cuid())
  userId      String
  questId     String
  status      QuestStatus @default(PENDING)
  proofLink   String?
  completedAt DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  quest       Quest       @relation(fields: [questId], references: [id])
  user        User        @relation(fields: [userId], references: [walletAddress])

  @@unique([userId, questId])
}

model ClaimedNFT {
  mintAddress String   @id @unique
  claimedBy   String
  claimedAt   DateTime @default(now())
}

model GuessGame {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastAttempt   DateTime @default(now())
  attempts      Int      @default(0)
  isLocked      Boolean  @default(false)
  pendingPoints Int      @default(0)
  currentTarget Int?
}

model PulseHunterGame {
  id             String   @id @default(cuid())
  userId         String   @unique
  lastAttempt    DateTime @default(now())
  attempts       Int      @default(0)
  isLocked       Boolean  @default(false)
  pendingSkr     Float    @default(0)
  currentTarget  Int?
}

enum QuestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model StakedNFT {
  id           String   @id @default(cuid())
  mintAddress  String   @unique  // <--- CRITICAL: This prevents double-staking
  ownerAddress String
  stakedAt     DateTime @default(now())
  lastClaimed  DateTime @default(now())
  // signature String? // Add this if you want to store the TX proof
}

model SupportTicket {
  id            String   @id @default(cuid())
  walletAddress String
  type          String   // Complaint or Suggestion
  name          String
  email         String
  title         String
  description   String   @db.Text
  status        String   @default("Pending") // Pending, Resolved
  isAIGenerated   Boolean  @default(false)
  aiSummary       String?  @db.Text
  suggestedAction String?
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

model RewardHistory {
  id            String   @id @default(cuid())
  walletAddress String
  mintAddress   String
  laamEarned    Float
  tagEarned     Float
  unstakedAt    DateTime @default(now())

  @@index([walletAddress])
}


model MultiplierBoost {
  id          String   @id @default(cuid())
  userAddress String
  mintAddress String   // Added this to target specific NFTs
  user        User     @relation(fields: [userAddress], references: [walletAddress])
  multiplier  Float    
  activatedAt DateTime @default(now()) // When the boost starts working
  expiresAt   DateTime
  purchasedAt DateTime @default(now())

  @@index([userAddress])
  @@index([mintAddress])
}

model RafflePool {
  id           String        @id @default(cuid())
  entryFee     Float         // 500, 1000, etc.
  status       String        @default("OPEN") // OPEN, DRAWING, COMPLETED, EXPIRED
  winnerAddress String?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  entries      RaffleEntry[]
}

model RaffleEntry {
  id            String     @id @default(cuid())
  poolId        String
  walletAddress String
  txSignature   String     @unique
  status        String      @default("PENDING")
  pool          RafflePool @relation(fields: [poolId], references: [id])
  createdAt     DateTime   @default(now())

  @@unique([poolId, walletAddress]) // Prevents one user entering same pool twice
}

model PushSubscription {
  id            String   @id @default(cuid())
  walletAddress String
  user          User     @relation(fields: [walletAddress], references: [walletAddress])
  subscription  Json     
  userAgent     String?  // Optional: helps you identify which device this is
  createdAt     DateTime @default(now())
  @@unique([walletAddress, userAgent])
}

model ResistanceScore {
  id            String   @id @default(cuid())
  walletAddress String
  initialGrid   String   // Store as a comma-separated string or JSON
  score         Int
  createdAt     DateTime @default(now())
  
  @@index([walletAddress])
  @@index([createdAt]) // For Daily Leaderboard filtering
}

model GameInvite {
  id          String   @id @default(cuid())
  senderId    String   // Wallet Address
  receiverId  String   // Wallet Address
  gameType    String   // e.g., "RAFFLE"
  poolId      String?  // The specific raffle pool
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt   DateTime @default(now())
}

model UsedSignature {
  id        String   @id @default(cuid())
  signature String   @unique
  userId    String
  purpose   String
  createdAt DateTime @default(now())
}
model Badge {
  id           String      @id @default(cuid())
  name         String      @unique 
  minPoints    Int         
  cmId         String      
  collectionId String      
  claimedBy    UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String   // This will now correctly store the walletAddress
  badgeId   String
  mintDate  DateTime @default(now())
  signature String   @unique 

  // This tells Prisma: "Use the walletAddress to identify the user"
  user      User     @relation(fields: [userId], references: [walletAddress])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId]) 
}

model DeployedWarrior {
  mintAddress   String   @id
  ownerAddress  String
  rarity        String   // "Common", "Rare", etc.
  image         String?
  deployedAt    DateTime @default(now())
  status       String   @default("IDLE") // "IDLE" (in barracks) or "DEPLOYED" (on mission)
  location     String?  // "NORMAL" or "VIP"
  missionEnd   DateTime? // deployedAt + 24 hours
  user          User     @relation(fields: [ownerAddress], references: [walletAddress])
}

model WarriorInventory {
  id            String   @id @default(cuid())
  walletAddress String
  itemId        String   // Matches the ID in armory.json (e.g., "wpn-001")
  category      String   // WEAPON, PET, GARMENT
  acquiredAt    DateTime @default(now())
  user          User     @relation(fields: [walletAddress], references: [walletAddress])
}